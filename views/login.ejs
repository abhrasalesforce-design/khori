<%- include('partials/header') %>

<div class="auth-container">
  <h1 style="color:#546B41;">Welcome Back</h1>
  <p class="auth-subtitle" style="color:#546B41;">Sign in to your account</p>
  <% if (error && error.length) { %><div class="alert alert-error"><%= error %></div><% } %>
  <% if (success && success.length) { %><div class="alert alert-success"><%= success %></div><% } %>

  <form method="POST" action="/login" class="auth-form">
    <% if (googleEnabled) { %>
    <a href="/auth/google" class="btn-google" style="display:flex;justify-content:center;align-items:center;text-align:center;width:100%;">
      <svg width="18" height="18" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg"><path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.875 2.684-6.615z" fill="#4285F4"/><path d="M9 18c2.43 0 4.467-.806 5.956-2.184l-2.908-2.258c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z" fill="#34A853"/><path d="M3.964 10.707A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.707V4.961H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.039l3.007-2.332z" fill="#FBBC05"/><path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.961L3.964 7.293C4.672 5.163 6.656 3.58 9 3.58z" fill="#EA4335"/></svg>
      Continue with Google
    </a>
    <div class="auth-divider" style="display:flex;align-items:center;width:100%;text-align:center;"><span style="text-align:center;width:100%;">or</span></div>
    <% } %>
    <input type="email" name="email" placeholder="Email address" required>
    <input type="password" name="password" placeholder="Password" required>
    <button type="submit" class="btn-primary" style="background:#546B41;border-color:#546B41;color:#fff;">Login</button>
  </form>
  <p class="auth-link">Don't have an account? <a href="/register">Register</a></p>
</div>

<%- include('partials/footer') %>
