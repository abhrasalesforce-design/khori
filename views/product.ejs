<%- include('partials/header') %>

<div class="product-detail-page">

  <!-- Breadcrumb -->
  <div class="pd-breadcrumb">
    <a href="/">Shop</a>
    <% if (product.category) { %>
      <span class="pd-sep">/</span>
      <a href="/?category=<%= product.category %>"><%= product.category.charAt(0).toUpperCase() + product.category.slice(1) %></a>
    <% } %>
    <span class="pd-sep">/</span>
    <span><%= product.name %></span>
  </div>

  <!-- Two-column layout -->
  <div class="pd-layout">

    <!-- Left: image / carousel -->
    <div class="pd-image-col">
      <%
        let pdImages = [];
        try { pdImages = product.images ? JSON.parse(product.images) : []; } catch(e) {}
        if (pdImages.length === 0 && product.image) pdImages = [product.image];
        if (pdImages.length === 0) pdImages = ['placeholder.jpg'];
        const toUrl = img => img.startsWith('http') ? img : '/uploads/' + img;
      %>
      <% if (pdImages.length > 1) { %>
      <div class="pd-carousel" id="pdCarousel">
        <div class="pd-carousel-track" id="pdCarouselTrack">
          <% pdImages.forEach((img, i) => { %>
            <div class="pd-carousel-slide">
              <img
                src="<%= toUrl(img) %>"
                alt="<%= product.name %> — image <%= i + 1 %>"
                loading="<%= i === 0 ? 'eager' : 'lazy' %>"
                decoding="async"
                onerror="this.src='/images/placeholder.jpg'"
              >
            </div>
          <% }) %>
        </div>
        <button class="pd-carousel-prev" aria-label="Previous image">&#8592;</button>
        <button class="pd-carousel-next" aria-label="Next image">&#8594;</button>
        <div class="pd-carousel-thumbs">
          <% pdImages.forEach((img, i) => { %>
            <button class="pd-carousel-thumb <%= i === 0 ? 'active' : '' %>" data-index="<%= i %>">
              <img src="<%= toUrl(img) %>" alt="" loading="lazy" onerror="this.src='/images/placeholder.jpg'">
            </button>
          <% }) %>
        </div>
      </div>
      <% } else { %>
      <div class="pd-image-wrap">
        <img
          src="<%= toUrl(pdImages[0]) %>"
          alt="<%= product.name %>"
          loading="eager"
          decoding="async"
          onerror="this.src='/images/placeholder.jpg'"
        >
      </div>
      <% } %>
    </div>

    <!-- Right: product info -->
    <div class="pd-info-col">

      <!-- Category tag -->
      <% if (product.category) { %>
        <p class="pd-category"><%= product.category.toUpperCase() %></p>
      <% } %>

      <!-- Name -->
      <h1 class="pd-name"><%= product.name %></h1>

      <!-- Price -->
      <div class="pd-price-row">
        <span class="pd-price">₹<%= Math.floor(product.price * 0.5) %></span>
        <span class="price-original" style="font-size:1rem;color:#aaa;text-decoration:line-through;font-family:'Inter',sans-serif;">₹<%= product.price.toFixed(0) %></span>
        <span class="price-badge" style="background:#F5AFAF;color:#fff;font-size:0.7rem;font-weight:700;letter-spacing:0.08em;padding:3px 8px;border-radius:4px;font-family:'Inter',sans-serif;">50% OFF</span>
      </div>
      <p class="pd-tax-note" style="margin-top:4px;">Inclusive of all taxes</p>

      <!-- Divider -->
      <div class="pd-divider"></div>

      <!-- Quantity + Buttons -->
      <% if (product.stock > 0) { %>
        <form method="POST" action="/cart/add" class="pd-add-form" id="pdAddForm">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="product_id" value="<%= product.id %>">

          <!-- Qty stepper + Add to Cart on same row -->
          <div class="pd-action-row">
            <div class="pd-qty-ctrl">
              <button type="button" onclick="pdQtyChange(-1)">−</button>
              <input type="number" name="quantity" id="pdQtyInput" value="1" min="1" max="<%= product.stock %>" readonly>
              <button type="button" onclick="pdQtyChange(1)">+</button>
            </div>
            <button type="submit" class="pd-btn-cart">Add to Cart</button>
          </div>

          <!-- In stock pill -->
          <div class="pd-instock-pill">
            <span class="pd-stock-dot"></span>
            In stock &ndash; ready to ship
          </div>

          <!-- Wishlist button -->
          <button type="button" class="pd-btn-wishlist<%= isWishlisted ? ' wishlisted' : '' %>" id="wishlistBtn" data-product-id="<%= product.id %>">
            <svg class="heart-icon" width="18" height="18" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
            </svg>
            <span class="wishlist-label"><%= isWishlisted ? 'Wishlisted' : 'Add to Wishlist' %></span>
          </button>
        </form>
      <% } else { %>
        <div class="pd-out-of-stock-row">
          <button class="pd-btn-cart pd-btn-disabled" disabled>Sold Out</button>
        </div>
        <button type="button" class="pd-btn-wishlist<%= isWishlisted ? ' wishlisted' : '' %>" id="wishlistBtn" data-product-id="<%= product.id %>">
          <svg class="heart-icon" width="18" height="18" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
          </svg>
          <span class="wishlist-label"><%= isWishlisted ? 'Wishlisted' : 'Add to Wishlist' %></span>
        </button>
      <% } %>

      <!-- Trust badges -->
      <div class="pd-trust">
        <div class="pd-trust-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#898AC4" stroke-width="1.5"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          <span>Free shipping above ₹699</span>
        </div>
        <div class="pd-trust-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#898AC4" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span>Secure checkout</span>
        </div>
        <div class="pd-trust-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#898AC4" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
          <span>Handcrafted with love</span>
        </div>
      </div>

      <!-- Description moved below trust badges -->
      <p class="pd-description"><%= product.description || 'No description available.' %></p>

      <!-- Three accordions -->
      <div class="pd-accordions">

        <!-- Details -->
        <div class="pd-accordion">
          <button class="pd-accordion-trigger" type="button" onclick="toggleAcc(this)">
            <span>Details</span>
            <svg class="pd-accordion-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="pd-accordion-body" hidden>
            <ul class="pd-details-list">
              <% if (product.material) { %><li><span>Material</span><%= product.material %></li><% } %>
              <% if (product.dimension) { %><li><span>Dimensions</span><%= product.dimension %></li><% } %>
              <% if (product.craft_type) { %><li><span>Craft</span><%= product.craft_type %></li><% } %>
              <% if (product.origin) { %><li><span>Origin</span><%= product.origin %></li><% } %>
              <% if (product.category) { %><li><span>Category</span><%= product.category.charAt(0).toUpperCase() + product.category.slice(1) %></li><% } %>
              <li><span>Made In</span>India</li>
            </ul>
          </div>
        </div>

        <!-- Care -->
        <div class="pd-accordion">
          <button class="pd-accordion-trigger" type="button" onclick="toggleAcc(this)">
            <span>Product Care</span>
            <svg class="pd-accordion-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="pd-accordion-body" hidden>
            <ul class="pd-details-list">
              <% if (product.care_instructions) { %>
                <li><span>Care</span><%= product.care_instructions %></li>
              <% } else { %>
                <li><span>Care</span>Wipe clean with a soft dry cloth. Avoid prolonged exposure to moisture or direct sunlight.</li>
              <% } %>
              <li><span>Storage</span>Store in a cool, dry place away from direct sunlight.</li>
            </ul>
          </div>
        </div>

        <!-- Shipping -->
        <div class="pd-accordion">
          <button class="pd-accordion-trigger" type="button" onclick="toggleAcc(this)">
            <span>Shipping &amp; Returns</span>
            <svg class="pd-accordion-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="pd-accordion-body" hidden>
            <ul class="pd-details-list">
              <li><span>Shipping</span>Free shipping on orders above ₹699. Standard delivery in 5–7 business days.</li>
              <li><span>Returns</span>We accept returns within 7 days of delivery for unused, undamaged items.</li>
              <li><span>Support</span>Contact us for any queries about your order.</li>
            </ul>
          </div>
        </div>

      </div><!-- /.pd-accordions -->

    </div><!-- /.pd-info-col -->
  </div><!-- /.pd-layout -->

</div>

<script>
  function pdQtyChange(delta) {
    const input = document.getElementById('pdQtyInput');
    if (!input) return;
    const max = parseInt(input.max, 10) || 99;
    input.value = Math.max(1, Math.min(max, parseInt(input.value, 10) + delta));
  }

  function toggleAcc(btn) {
    const body = btn.nextElementSibling;
    const open = !body.hidden;
    body.hidden = open;
    btn.classList.toggle('open', !open);
  }

  (function() {
    const btn = document.getElementById('wishlistBtn');
    if (!btn) return;
    const isLoggedIn = <%= user ? 'true' : 'false' %>;
    btn.addEventListener('click', async function() {
      if (!isLoggedIn) { alert('Please login to save to wishlist'); return; }
      try {
        const res = await fetch('/wishlist/toggle', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
          },
          body: 'product_id=' + encodeURIComponent(btn.dataset.productId)
        });
        const data = await res.json();
        if (data.wishlisted) {
          btn.classList.add('wishlisted');
          btn.querySelector('.wishlist-label').textContent = 'Wishlisted';
        } else {
          btn.classList.remove('wishlisted');
          btn.querySelector('.wishlist-label').textContent = 'Add to Wishlist';
        }
      } catch(e) { alert('Something went wrong.'); }
    });
  })();
</script>

<script>
(function() {
  const carousel = document.getElementById('pdCarousel');
  if (!carousel) return;
  const track = document.getElementById('pdCarouselTrack');
  const slides = track.querySelectorAll('.pd-carousel-slide');
  const thumbs = carousel.querySelectorAll('.pd-carousel-thumb');
  let current = 0;

  function goTo(n) {
    slides[current].classList.remove('active');
    thumbs[current].classList.remove('active');
    current = (n + slides.length) % slides.length;
    slides[current].classList.add('active');
    thumbs[current].classList.add('active');
    track.style.transform = 'translateX(-' + (current * 100) + '%)';
  }

  carousel.querySelector('.pd-carousel-prev').addEventListener('click', () => goTo(current - 1));
  carousel.querySelector('.pd-carousel-next').addEventListener('click', () => goTo(current + 1));
  thumbs.forEach(t => t.addEventListener('click', () => goTo(+t.dataset.index)));

  // Swipe support
  let startX = 0;
  track.addEventListener('touchstart', e => { startX = e.touches[0].clientX; }, { passive: true });
  track.addEventListener('touchend', e => {
    const diff = startX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 40) goTo(diff > 0 ? current + 1 : current - 1);
  });

  slides[0].classList.add('active');
})();
</script>

<%- include('partials/footer') %>
