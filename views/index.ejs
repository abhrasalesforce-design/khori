<%- include('partials/header') %>

<section class="hero">
  <div class="hero-inner">
    <span class="hero-eyebrow">New Collection 2026</span>
    <h1>Crafted by<br><em>Hand</em>, Made<br>with Heart</h1>
    <p>Discover unique handmade pieces that bring warmth, story, and soul into your home.</p>
    <a href="#shop" class="hero-cta">Explore Collection</a>
  </div>
</section>

<div class="marquee-strip">
  <div class="marquee-inner">
    <span>Handmade Crafts</span>
    <span>Free Shipping</span>
    <span>Unique Pieces</span>
    <span>Made with Love</span>
    <span>Artisan Quality</span>
    <span>Handmade Crafts</span>
    <span>Free Shipping</span>
    <span>Unique Pieces</span>
    <span>Made with Love</span>
    <span>Artisan Quality</span>
  </div>
</div>

<!-- ===== Company Intro ===== -->
<section class="company-intro">
  <div class="intro-inner">
    <div class="intro-text">
      <span class="intro-eyebrow">Our Story</span>
      <h2>Where Tradition Meets<br><em>Craft</em></h2>
      <p>Hathe Khori — meaning "learning by hand" — is a celebration of India's living craft traditions. We work directly with local artisans from Bengal and beyond, bringing their timeless skills to your doorstep.</p>
      <p>Every piece you find here is made by hand, carrying the story of the maker — their patience, their pride, and their generations of knowledge passed down through touch.</p>
      <div class="intro-stats">
        <div class="intro-stat">
          <span class="stat-n">50+</span>
          <span class="stat-l">Artisans</span>
        </div>
        <div class="intro-stat">
          <span class="stat-n">200+</span>
          <span class="stat-l">Products</span>
        </div>
        <div class="intro-stat">
          <span class="stat-n">8</span>
          <span class="stat-l">Art Forms</span>
        </div>
      </div>
    </div>
    <div class="intro-visual">
      <div class="intro-img-block">
        <img src="/images/logo.png" alt="Hathe Khori" class="intro-logo-img">
        <div class="intro-tag">Founded in Tradition</div>
      </div>
    </div>
  </div>
</section>

<!-- ===== Art Forms ===== -->
<section class="artforms-section">
  <div class="artforms-header">
    <span class="intro-eyebrow">What We Celebrate</span>
    <h2>The Art Forms</h2>
    <p>Each craft is a living language — shaped by soil, season, and soul.</p>
  </div>

  <div class="artforms-grid">

    <div class="artform-card" style="--bg: #FAE7EB">
      <div class="artform-front">
        <div class="artform-icon">🏺</div>
        <h3>Pottery</h3>
        <span class="artform-origin">Bengal · Bihar</span>
      </div>
      <div class="artform-back">
        <h3>Pottery</h3>
        <p>Shaped on the wheel from river clay, each pot carries the fingerprints of its maker. Terracotta vessels painted with folk motifs — timeless, earthy, alive.</p>
        <a href="/?category=pottery" class="artform-btn">Shop Pottery</a>
      </div>
    </div>

    <div class="artform-card" style="--bg: #E0D4E7">
      <div class="artform-front">
        <div class="artform-icon">🧵</div>
        <h3>Textile</h3>
        <span class="artform-origin">Bengal · Rajasthan</span>
      </div>
      <div class="artform-back">
        <h3>Textile</h3>
        <p>Block-printed fabrics, handwoven cotton, macramé knotted with patience — our textiles are stories told in thread, colour, and pattern.</p>
        <a href="/?category=textile" class="artform-btn">Shop Textiles</a>
      </div>
    </div>

    <div class="artform-card" style="--bg: #EECEDA">
      <div class="artform-front">
        <div class="artform-icon">🪵</div>
        <h3>Woodwork</h3>
        <span class="artform-origin">Bengal · Orissa</span>
      </div>
      <div class="artform-back">
        <h3>Woodwork</h3>
        <p>Carved from mango and sheesham wood by chisels passed down through families. Each piece holds the grain of the tree and the mark of the carver.</p>
        <a href="/?category=woodwork" class="artform-btn">Shop Woodwork</a>
      </div>
    </div>

    <div class="artform-card" style="--bg: #fdf3e3">
      <div class="artform-front">
        <div class="artform-icon">🪔</div>
        <h3>Decor</h3>
        <span class="artform-origin">Pan India</span>
      </div>
      <div class="artform-back">
        <h3>Decor</h3>
        <p>Brass wind chimes, hand-painted lamps, woven baskets — objects that fill your home with warmth, rhythm, and the quiet beauty of the handmade.</p>
        <a href="/?category=decor" class="artform-btn">Shop Decor</a>
      </div>
    </div>

    <div class="artform-card" style="--bg: #e8f4e8">
      <div class="artform-front">
        <div class="artform-icon">🧺</div>
        <h3>Basket Weaving</h3>
        <span class="artform-origin">Bengal · Assam</span>
      </div>
      <div class="artform-back">
        <h3>Basket Weaving</h3>
        <p>Woven from jute, bamboo, and cane using centuries-old patterns. Functional, sustainable, and crafted with the rhythm of hands that know every knot.</p>
        <a href="/?category=basket" class="artform-btn">Shop Baskets</a>
      </div>
    </div>

    <div class="artform-card" style="--bg: #fef9e7">
      <div class="artform-front">
        <div class="artform-icon">💎</div>
        <h3>Jewellery</h3>
        <span class="artform-origin">Bengal · Rajasthan</span>
      </div>
      <div class="artform-back">
        <h3>Jewellery</h3>
        <p>Handcrafted in silver, brass, and beads — each ornament is shaped by flame and file. Adornments that carry culture and grace in every curve.</p>
        <a href="/?category=jewellery" class="artform-btn">Shop Jewellery</a>
      </div>
    </div>

  </div>
</section>

<!-- ===== Shop ===== -->
<div id="shop">
  <div class="shop-section-header">
    <h2>All Products</h2>
    <form method="GET" action="/" class="search-form">
      <input type="text" name="search" placeholder="Search..." value="<%= search || '' %>">
      <button type="submit">Search</button>
    </form>
  </div>

  <div class="shop-controls">
    <div class="categories">
      <a href="/" class="cat-btn <%= !category ? 'active' : '' %>">All</a>
      <% categories.forEach(cat => { %>
        <a href="/?category=<%= cat %>" class="cat-btn <%= category === cat ? 'active' : '' %>"><%= cat %></a>
      <% }) %>
    </div>
  </div>

  <section class="product-grid">
    <% if (products.length === 0) { %>
      <div class="empty"><p>No products found.</p><a href="/" class="btn-primary">View All</a></div>
    <% } else { %>
      <% products.forEach(product => { %>
        <div class="product-card">
          <a href="/product/<%= product.id %>">
            <img src="/uploads/<%= product.image %>" alt="<%= product.name %>" onerror="this.src='/images/placeholder.jpg'">
            <div class="product-info">
              <p class="product-category"><%= product.category %></p>
              <h3><%= product.name %></h3>
              <p class="price">₹<%= product.price.toFixed(2) %></p>
              <p class="stock <%= product.stock === 0 ? 'out' : '' %>">
                <%= product.stock > 0 ? `${product.stock} in stock` : 'Out of stock' %>
              </p>
            </div>
          </a>
          <% if (product.stock > 0) { %>
            <form method="POST" action="/cart/add">
              <input type="hidden" name="product_id" value="<%= product.id %>">
              <input type="hidden" name="quantity" value="1">
              <button type="submit" class="btn-add">Add to Cart</button>
            </form>
          <% } %>
        </div>
      <% }) %>
    <% } %>
  </section>
</div>

<%- include('partials/footer') %>
