<%- include('partials/header') %>

<!-- ===== Hero Carousel ===== -->
<section class="hero-carousel" id="heroCarousel">

  <!-- Slide 1 — Welcome to Hathekhori -->
  <div class="hero-slide active" style="background-image: linear-gradient(rgba(250,231,235,0.88), rgba(224,212,231,0.88)), url('/images/salt.jpeg'); background-size: cover; background-position: center;">
    <div class="hero-slide-inner hero-slide-about">
      <span class="hero-eyebrow">Welcome to হাতেখড়ি</span>
      <h1><em>Hathekhori</em></h1>
      <p class="hero-tagline-italic">Every journey begins with a first stroke.</p>
      <p>In Bengali culture, Hathekhori symbolizes a child's very first step into learning, creativity, and self-expression — the moment when a hand first holds chalk to create something meaningful.</p>
      <p>We chose the name <strong>হাতেখড়ি</strong> because art and craft begin the same way: with curiosity, imagination, and the courage to create. What starts as a simple idea slowly transforms into stories, colors, emotions, and handmade expressions.</p>
      <a href="#shop" class="hero-cta">Explore Our Work</a>
    </div>
  </div>

  <!-- Slide 2 — New Collection 2026 -->
  <div class="hero-slide" style="background: linear-gradient(135deg, var(--blush) 0%, var(--lavender) 50%, var(--rose) 100%);">
    <div class="hero-slide-inner">
      <span class="hero-eyebrow">New Collection 2026</span>
      <h1>Crafted by<br><em>Hand</em>, Made<br>with Heart</h1>
      <p>Discover unique handmade pieces that bring warmth, story, and soul into your home.</p>
      <a href="#shop" class="hero-cta">Explore Collection</a>
    </div>
  </div>

  <!-- Controls -->
  <button class="hero-prev" aria-label="Previous slide">&#8592;</button>
  <button class="hero-next" aria-label="Next slide">&#8594;</button>

  <!-- Dots -->
  <div class="hero-dots">
    <button class="hero-dot active" data-index="0"></button>
    <button class="hero-dot" data-index="1"></button>
  </div>

  <!-- Slide counter -->
  <div class="hero-counter"><span class="hero-counter-cur">01</span><span class="hero-counter-sep">/</span><span class="hero-counter-tot">02</span></div>
</section>

<script>
(function() {
  const slides = document.querySelectorAll('.hero-slide');
  const dots   = document.querySelectorAll('.hero-dot');
  const cur    = document.querySelector('.hero-counter-cur');
  let idx = 0, timer;

  function go(n) {
    slides[idx].classList.remove('active');
    dots[idx].classList.remove('active');
    idx = (n + slides.length) % slides.length;
    slides[idx].classList.add('active');
    dots[idx].classList.add('active');
    cur.textContent = String(idx + 1).padStart(2, '0');
  }

  function start() { timer = setInterval(() => go(idx + 1), 5000); }
  function stop()  { clearInterval(timer); }

  document.querySelector('.hero-next').addEventListener('click', () => { stop(); go(idx + 1); start(); });
  document.querySelector('.hero-prev').addEventListener('click', () => { stop(); go(idx - 1); start(); });
  dots.forEach(d => d.addEventListener('click', () => { stop(); go(+d.dataset.index); start(); }));

  start();
})();
</script>

<div class="marquee-strip">
  <div class="marquee-inner">
    <span>Handmade Crafts</span><span>Free Shipping</span><span>Unique Pieces</span>
    <span>Made with Love</span><span>Artisan Quality</span><span>Handmade Crafts</span>
    <span>Free Shipping</span><span>Unique Pieces</span><span>Made with Love</span><span>Artisan Quality</span>
  </div>
</div>

<!-- ===== Shop ===== -->
<section id="shop">
  <div class="shop-section-header">
    <h2>Art Works</h2>
    <form method="GET" action="/" class="search-form">
      <input type="text" name="search" placeholder="Search..." value="<%= search || '' %>">
      <button type="submit">Search</button>
    </form>
  </div>

  <div class="shop-controls">
    <div class="categories">
      <a href="/#shop" class="cat-btn <%= !category ? 'active' : '' %>">All</a>
      <% categories.forEach(cat => { %>
        <a href="/?category=<%= cat %>#shop" class="cat-btn <%= category === cat ? 'active' : '' %>"><%= cat %></a>
      <% }) %>
    </div>
  </div>

  <% if (products.length === 0) { %>
    <div class="empty"><p>No products found.</p><a href="/" class="btn-primary">View All</a></div>
  <% } else { %>
  <div class="product-grid">
    <% products.forEach(product => { %>
      <div class="product-card">
        <a href="/product/<%= product.id %>">
          <img src="<%= product.image && product.image.startsWith('http') ? product.image : '/uploads/' + product.image %>" alt="<%= product.name %>" onerror="this.src='/images/placeholder.jpg'">
          <div class="product-info">
            <p class="product-category"><%= product.category %></p>
            <h3><%= product.name %></h3>
            <p class="price">₹<%= product.price.toFixed(2) %></p>
            <p class="stock <%= product.stock === 0 ? 'out' : '' %>">
              <%= product.stock > 0 ? `${product.stock} in stock` : 'Out of stock' %>
            </p>
          </div>
        </a>
        <% if (product.stock > 0) { %>
          <form method="POST" action="/cart/add">
            <input type="hidden" name="product_id" value="<%= product.id %>">
            <input type="hidden" name="quantity" value="1">
            <button type="submit" class="btn-add">Add to Cart</button>
          </form>
        <% } %>
      </div>
    <% }) %>
  </div>
  <% } %>
</section>

<!-- ===== Art Forms Carousel ===== -->
<section class="artforms-section" id="artforms">
  <div class="artforms-header">
    <span class="intro-eyebrow">What We Celebrate</span>
    <h2>The Art Forms</h2>
    <p>Each craft is a living language — shaped by soil, season, and soul.</p>
  </div>

  <div class="artforms-carousel-wrap">
    <button class="carousel-btn carousel-prev" aria-label="Previous">&#8592;</button>
    <div class="artforms-carousel" id="artformsCarousel">
      <div class="artforms-track" id="artformsTrack">

        <div class="artform-card" style="--bg: #FAE7EB">
          <div class="artform-inner">
            <div class="artform-icon">🏺</div>
            <h3>Pottery</h3>
            <span class="artform-origin">Bengal · Bihar</span>
            <p>Shaped on the wheel from river clay, each pot carries the fingerprints of its maker. Terracotta vessels painted with folk motifs — timeless, earthy, alive.</p>
            <a href="/?category=pottery#shop" class="artform-btn">Shop Pottery →</a>
          </div>
        </div>

        <div class="artform-card" style="--bg: #E0D4E7">
          <div class="artform-inner">
            <div class="artform-icon">🧵</div>
            <h3>Textile</h3>
            <span class="artform-origin">Bengal · Rajasthan</span>
            <p>Block-printed fabrics, handwoven cotton, macramé knotted with patience — stories told in thread, colour, and pattern.</p>
            <a href="/?category=textile#shop" class="artform-btn">Shop Textiles →</a>
          </div>
        </div>

        <div class="artform-card" style="--bg: #EECEDA">
          <div class="artform-inner">
            <div class="artform-icon">🪵</div>
            <h3>Woodwork</h3>
            <span class="artform-origin">Bengal · Orissa</span>
            <p>Carved from mango and sheesham wood by chisels passed down through families. Each piece holds the grain of the tree.</p>
            <a href="/?category=woodwork#shop" class="artform-btn">Shop Woodwork →</a>
          </div>
        </div>

        <div class="artform-card" style="--bg: #fdf3e3">
          <div class="artform-inner">
            <div class="artform-icon">🪔</div>
            <h3>Decor</h3>
            <span class="artform-origin">Pan India</span>
            <p>Brass wind chimes, hand-painted lamps, woven baskets — objects that fill your home with warmth and quiet beauty.</p>
            <a href="/?category=decor#shop" class="artform-btn">Shop Decor →</a>
          </div>
        </div>

        <div class="artform-card" style="--bg: #e8f4e8">
          <div class="artform-inner">
            <div class="artform-icon">🧺</div>
            <h3>Basket Weaving</h3>
            <span class="artform-origin">Bengal · Assam</span>
            <p>Woven from jute, bamboo, and cane using centuries-old patterns. Functional, sustainable, and crafted with rhythm.</p>
            <a href="/?category=basket#shop" class="artform-btn">Shop Baskets →</a>
          </div>
        </div>

        <div class="artform-card" style="--bg: #fef9e7">
          <div class="artform-inner">
            <div class="artform-icon">💎</div>
            <h3>Jewellery</h3>
            <span class="artform-origin">Bengal · Rajasthan</span>
            <p>Handcrafted in silver, brass, and beads — each ornament is shaped by flame and file, carrying culture in every curve.</p>
            <a href="/?category=jewellery#shop" class="artform-btn">Shop Jewellery →</a>
          </div>
        </div>

        <div class="artform-card" style="--bg: #e8eaf6">
          <div class="artform-inner">
            <div class="artform-icon">🖌️</div>
            <h3>Painting</h3>
            <span class="artform-origin">Bengal · Madhubani</span>
            <p>Folk paintings in vivid colours — Patachitra, Madhubani, Kalighat — each stroke a prayer, each canvas a world of its own.</p>
            <a href="/?category=painting#shop" class="artform-btn">Shop Paintings →</a>
          </div>
        </div>

        <div class="artform-card" style="--bg: #fce4ec">
          <div class="artform-inner">
            <div class="artform-icon">🪆</div>
            <h3>Clay Craft</h3>
            <span class="artform-origin">Bengal · Bishnupur</span>
            <p>Miniature clay figurines, Bankura horses, Durga idols — shaped by hand and fired in earth kilns, full of festive spirit.</p>
            <a href="/?category=clay#shop" class="artform-btn">Shop Clay Craft →</a>
          </div>
        </div>

      </div>
    </div>
    <button class="carousel-btn carousel-next" aria-label="Next">&#8594;</button>
  </div>
  <div class="carousel-dots" id="carouselDots"></div>
</section>

<script>
(function() {
  const track = document.getElementById('artformsTrack');
  const carousel = document.getElementById('artformsCarousel');
  const dotsContainer = document.getElementById('carouselDots');
  const cards = track.querySelectorAll('.artform-card');
  let current = 0;
  let autoTimer;

  function getVisible() {
    if (window.innerWidth < 600) return 1;
    if (window.innerWidth < 900) return 2;
    if (window.innerWidth < 1200) return 3;
    return 4;
  }

  const total = cards.length;

  function buildDots() {
    dotsContainer.innerHTML = '';
    const pages = Math.ceil(total / getVisible());
    for (let i = 0; i < pages; i++) {
      const d = document.createElement('button');
      d.className = 'carousel-dot' + (i === 0 ? ' active' : '');
      d.addEventListener('click', () => goTo(i * getVisible()));
      dotsContainer.appendChild(d);
    }
  }

  function updateDots() {
    const dots = dotsContainer.querySelectorAll('.carousel-dot');
    const page = Math.floor(current / getVisible());
    dots.forEach((d, i) => d.classList.toggle('active', i === page));
  }

  function goTo(index) {
    const visible = getVisible();
    const maxIndex = total - visible;
    current = Math.max(0, Math.min(index, maxIndex));
    const cardWidth = cards[0].offsetWidth + 20;
    track.style.transform = `translateX(-${current * cardWidth}px)`;
    updateDots();
  }

  function next() {
    const visible = getVisible();
    current = current + visible >= total ? 0 : current + 1;
    goTo(current);
  }

  function prev() {
    current = current <= 0 ? total - getVisible() : current - 1;
    goTo(current);
  }

  function startAuto() { stopAuto(); autoTimer = setInterval(next, 2500); }
  function stopAuto() { clearInterval(autoTimer); }

  document.querySelector('.carousel-next').addEventListener('click', () => { stopAuto(); next(); startAuto(); });
  document.querySelector('.carousel-prev').addEventListener('click', () => { stopAuto(); prev(); startAuto(); });
  carousel.addEventListener('mouseenter', stopAuto);
  carousel.addEventListener('mouseleave', startAuto);
  window.addEventListener('resize', () => { buildDots(); goTo(0); });

  buildDots();
  startAuto();
})();
</script>

