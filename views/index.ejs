<%- include('partials/header') %>

<!-- ===== Hero Carousel ===== -->
<section class="hero-carousel" id="heroCarousel">

  <!-- Slide 1 — Mini Canvas (LCP image: real <img> so browser discovers it immediately) -->
  <div class="hero-slide active hero-img-slide">
    <img class="hero-bg-img" src="<%= cdn['mini-canvas.jpg'] || '/images/mini-canvas.jpg' %>" alt="" fetchpriority="high" decoding="sync">
    <div class="hero-slide-inner hero-slide-overlay">
      <span class="hero-eyebrow">New Arrival</span>
      <h1>Mini <em>Canvas</em><br>Art</h1>
      <p>Tiny masterpieces, big emotions. Each mini canvas is hand-painted by Indian artisans — perfect for gifting or adorning your space.</p>
      <a href="/?category=decor#shop" class="hero-cta hero-cta-transparent">Shop Decor →</a>
    </div>
  </div>

  <!-- Slide 2 — Tote Bags (lazy: data-bg loaded on first activation) -->
  <div class="hero-slide hero-img-slide" data-bg="<%= cdn['totebags.jpg'] || '/images/totebags.jpg' %>">
    <div class="hero-slide-inner hero-slide-overlay">
      <span class="hero-eyebrow">Carry with Purpose</span>
      <h1>Handcrafted<br><em>Tote</em> Bags</h1>
      <p>Block-printed, hand-stitched, and made to last — our tote bags are a statement of sustainable style rooted in Indian craft traditions.</p>
      <a href="/?category=jewellery#shop" class="hero-cta hero-cta-transparent">Shop Collection →</a>
    </div>
  </div>

  <!-- Slide 3 — Gift Box (lazy: data-bg loaded on first activation) -->
  <div class="hero-slide hero-img-slide" data-bg="<%= cdn['stationary.jpg'] || '/images/stationary.jpg' %>">
    <div class="hero-slide-inner hero-slide-overlay">
      <span class="hero-eyebrow">Curate & Gift</span>
      <h1>Build Your Own<br><em>Gift Box</em></h1>
      <p>Pick from our handcrafted stationery — notebooks, hand-painted pens, wax seals, and more — to create a gift box as unique as the person receiving it.</p>
      <a href="/?category=others#shop" class="hero-cta hero-cta-transparent">Build Your Box →</a>
    </div>
  </div>

  <!-- Controls -->
  <button class="hero-prev" aria-label="Previous slide">&#8592;</button>
  <button class="hero-next" aria-label="Next slide">&#8594;</button>

  <!-- Dots -->
  <div class="hero-dots">
    <button class="hero-dot active" data-index="0"></button>
    <button class="hero-dot" data-index="1"></button>
    <button class="hero-dot" data-index="2"></button>
  </div>

  <!-- Slide counter -->
  <div class="hero-counter"><span class="hero-counter-cur">01</span><span class="hero-counter-sep">/</span><span class="hero-counter-tot">03</span></div>
</section>

<script>
(function() {
  const slides = document.querySelectorAll('.hero-slide');
  const dots   = document.querySelectorAll('.hero-dot');
  const cur    = document.querySelector('.hero-counter-cur');
  let idx = 0, timer;

  function loadBg(slide) {
    const bg = slide.dataset.bg;
    if (bg && !slide.style.backgroundImage) slide.style.backgroundImage = 'url(' + bg + ')';
  }

  function go(n) {
    slides[idx].classList.remove('active');
    dots[idx].classList.remove('active');
    idx = (n + slides.length) % slides.length;
    loadBg(slides[idx]);
    slides[idx].classList.add('active');
    dots[idx].classList.add('active');
    cur.textContent = String(idx + 1).padStart(2, '0');
  }

  function start() { timer = setInterval(() => go(idx + 1), 12000); }
  function stop()  { clearInterval(timer); }

  document.querySelector('.hero-next').addEventListener('click', () => { stop(); go(idx + 1); start(); });
  document.querySelector('.hero-prev').addEventListener('click', () => { stop(); go(idx - 1); start(); });
  dots.forEach(d => d.addEventListener('click', () => { stop(); go(+d.dataset.index); start(); }));

  start();
})();
</script>

<div class="marquee-strip">
  <div class="marquee-inner">
    <span>Handmade Crafts</span><span>Free Shipping on Orders Above ₹499</span><span>Unique Pieces</span>
    <span>Made with Love</span><span>Artisan Quality</span><span>Handmade Crafts</span>
    <span>Free Shipping on Orders Above ₹499</span><span>Unique Pieces</span><span>Made with Love</span><span>Artisan Quality</span>
  </div>
</div>

<!-- ===== Shop ===== -->
<section id="shop">

  <!-- Section header -->
  <div class="cc-header">
    <span class="cc-eyebrow">Handpicked for You</span>
    <h2 class="cc-title">Craft Collection</h2>
    <p class="cc-subtitle">Each piece is made by hand, rooted in tradition, and full of story.</p>
  </div>

  <!-- Sort + Search -->
  <div class="cc-controls">
    <div class="cc-sort-wrap">
      <label class="cc-sort-label">Sort By</label>
      <select class="cc-sort-select" onchange="window.location.href=this.value + '#shop'">
        <option value="/" <%= !category && !search ? 'selected' : '' %>>Latest</option>
        <option value="/?sort=price-asc" <%= locals.sort === 'price-asc' ? 'selected' : '' %>>Price: Low to High</option>
        <option value="/?sort=price-desc" <%= locals.sort === 'price-desc' ? 'selected' : '' %>>Price: High to Low</option>
        <option value="/?sort=name-asc" <%= locals.sort === 'name-asc' ? 'selected' : '' %>>Name: A–Z</option>
        <option value="/?sort=name-desc" <%= locals.sort === 'name-desc' ? 'selected' : '' %>>Name: Z–A</option>
      </select>
    </div>
    <form method="GET" action="/" class="cc-search">
      <% if (category) { %><input type="hidden" name="category" value="<%= category %>"><% } %>
      <input type="text" name="search" placeholder="Search crafts..." value="<%= search || '' %>">
      <button type="submit">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </button>
    </form>
  </div>

  <% if (products.length === 0) { %>
    <div class="empty"><p>No products found.</p><a href="/" class="btn-primary">View All</a></div>
  <% } else { %>
  <div class="cc-grid">
    <% products.forEach(product => { %>
      <div class="cc-card">
        <a href="/product/<%= product.id %>" class="cc-card-img-wrap">
          <img src="<%= product.image && product.image.startsWith('http') ? product.image : '/uploads/' + product.image %>" alt="<%= product.name %>" loading="lazy" decoding="async" onerror="this.src='/images/placeholder.jpg'">
          <span class="cc-card-overlay">
            <span class="cc-card-view">View Product</span>
          </span>
          <% if (product.stock > 0) { %>
            <span class="cc-card-badge">50% OFF</span>
          <% } else { %>
            <span class="cc-card-badge cc-card-badge-oos">Out of Stock</span>
          <% } %>
        </a>
        <div class="cc-card-body">
          <span class="cc-card-cat"><%= product.category %></span>
          <h3 class="cc-card-name"><%= product.name %></h3>
          <div class="cc-card-price">
            <span class="cc-price-now">₹<%= Math.floor(product.price * 0.5) %></span>
            <span class="cc-price-was">₹<%= product.price.toFixed(0) %></span>
          </div>
        </div>
        <% if (product.stock > 0) { %>
          <form method="POST" action="/cart/add" class="cc-card-form">
            <input type="hidden" name="product_id" value="<%= product.id %>">
            <input type="hidden" name="quantity" value="1">
            <button type="submit" class="cc-btn-add">Add to Cart</button>
          </form>
        <% } %>
      </div>
    <% }) %>
  </div>

  <% if (totalPages > 1) { %>
  <nav class="pagination" aria-label="Products pagination">
    <% const buildUrl = (p) => {
      let u = '/?page=' + p;
      if (category) u += '&category=' + encodeURIComponent(category);
      if (search)   u += '&search=' + encodeURIComponent(search);
      return u + '#shop';
    } %>

    <% if (currentPage > 1) { %>
      <a href="<%= buildUrl(currentPage - 1) %>" class="page-btn page-prev">&#8592;</a>
    <% } %>

    <% for (let p = 1; p <= totalPages; p++) { %>
      <a href="<%= buildUrl(p) %>" class="page-btn <%= p === currentPage ? 'active' : '' %>"><%= p %></a>
    <% } %>

    <% if (currentPage < totalPages) { %>
      <a href="<%= buildUrl(currentPage + 1) %>" class="page-btn page-next">&#8594;</a>
    <% } %>
  </nav>
  <% } %>

  <% } %>
</section>

<!-- ===== Art Forms Carousel ===== -->
<section class="artforms-section" id="artforms">
  <div class="artforms-header">
    <span class="intro-eyebrow">What We Celebrate</span>
    <h2>The Art Forms</h2>
    <p>Each craft is a living language — shaped by soil, season, and soul.</p>
  </div>

  <div class="artforms-carousel-wrap">
    <button class="carousel-btn carousel-prev" aria-label="Previous">&#8592;</button>
    <div class="artforms-carousel" id="artformsCarousel">
      <div class="artforms-track" id="artformsTrack">

        <div class="artform-card artform-card-img" style="background-image: url('<%= cdn["handblock.jpeg"] || "/images/handblock.jpeg" %>');">
          <div class="artform-inner artform-inner-overlay">
            <h3>Hand Block Fabric</h3>
            <span class="artform-origin">Rajasthan · Gujarat</span>
            <p>Carved wooden blocks dipped in natural dyes and pressed onto cotton by skilled hands — each print slightly imperfect, wholly beautiful. A tradition woven into the fabric of India for over 500 years.</p>
            <a href="/?category=jewellery#shop" class="artform-btn artform-btn-light">Shop Hand Block →</a>
          </div>
        </div>

        <div class="artform-card artform-card-img" style="background-image: url('<%= cdn["madhubani.jpg"] || "/images/madhubani.jpg" %>');">
          <div class="artform-inner artform-inner-overlay">
            <h3>Madhubani</h3>
            <span class="artform-origin">Mithila · Bihar</span>
            <p>Born in the villages of Mithila, Madhubani paintings fill every inch of the canvas with vivid geometry, nature, and myth. Passed from mother to daughter for generations — a living art that speaks without words.</p>
            <a href="/?category=decor#shop" class="artform-btn artform-btn-light">Shop Madhubani →</a>
          </div>
        </div>

        <div class="artform-card artform-card-img" style="background-image: url('<%= cdn["warli.jpeg"] || "/images/warli.jpeg" %>');">
          <div class="artform-inner artform-inner-overlay">
            <h3>Warli</h3>
            <span class="artform-origin">Maharashtra · Tribal</span>
            <p>White rice-paste painted on earthen walls by the Warli tribe — simple circles, triangles, and lines that tell stories of harvest, dance, and daily life. Ancient, minimal, and deeply human.</p>
            <a href="/?category=others#shop" class="artform-btn artform-btn-light">Shop Warli →</a>
          </div>
        </div>

        <div class="artform-card artform-card-img" style="background-image: url('<%= cdn["boho.jpg"] || "/images/boho.jpg" %>');">
          <div class="artform-inner artform-inner-overlay">
            <h3>Boho</h3>
            <span class="artform-origin">Free Spirit · Wanderer</span>
            <p>A soulful blend of earthy textures, natural materials, and free-spirited patterns — Boho craft celebrates individuality and the beauty of the unconventional. Every piece tells a story of wanderlust and wild creativity.</p>
            <a href="/?category=boho#shop" class="artform-btn artform-btn-light">Shop Boho →</a>
          </div>
        </div>

      </div>
    </div>
    <button class="carousel-btn carousel-next" aria-label="Next">&#8594;</button>
  </div>
  <div class="carousel-dots" id="carouselDots"></div>
</section>

<script>
(function() {
  const track = document.getElementById('artformsTrack');
  const carousel = document.getElementById('artformsCarousel');
  const dotsContainer = document.getElementById('carouselDots');
  const cards = track.querySelectorAll('.artform-card');
  let current = 0;
  let autoTimer;

  function getVisible() {
    if (window.innerWidth < 600) return 1;
    if (window.innerWidth < 900) return 2;
    if (window.innerWidth < 1200) return 3;
    return 4;
  }

  const total = cards.length;

  function buildDots() {
    dotsContainer.innerHTML = '';
    const pages = Math.ceil(total / getVisible());
    for (let i = 0; i < pages; i++) {
      const d = document.createElement('button');
      d.className = 'carousel-dot' + (i === 0 ? ' active' : '');
      d.addEventListener('click', () => goTo(i * getVisible()));
      dotsContainer.appendChild(d);
    }
  }

  function updateDots() {
    const dots = dotsContainer.querySelectorAll('.carousel-dot');
    const page = Math.floor(current / getVisible());
    dots.forEach((d, i) => d.classList.toggle('active', i === page));
  }

  let cachedCardWidth = 0;
  function getCardWidth() {
    if (!cachedCardWidth) cachedCardWidth = cards[0].offsetWidth + 20;
    return cachedCardWidth;
  }

  function goTo(index) {
    const visible = getVisible();
    const maxIndex = total - visible;
    current = Math.max(0, Math.min(index, maxIndex));
    track.style.transform = `translateX(-${current * getCardWidth()}px)`;
    updateDots();
  }

  function next() {
    const visible = getVisible();
    current = current + visible >= total ? 0 : current + 1;
    goTo(current);
  }

  function prev() {
    current = current <= 0 ? total - getVisible() : current - 1;
    goTo(current);
  }

  function startAuto() { stopAuto(); autoTimer = setInterval(next, 2500); }
  function stopAuto() { clearInterval(autoTimer); }

  document.querySelector('.carousel-next').addEventListener('click', () => { stopAuto(); next(); startAuto(); });
  document.querySelector('.carousel-prev').addEventListener('click', () => { stopAuto(); prev(); startAuto(); });
  carousel.addEventListener('mouseenter', stopAuto);
  carousel.addEventListener('mouseleave', startAuto);
  window.addEventListener('resize', () => { cachedCardWidth = 0; buildDots(); goTo(0); });

  buildDots();
  startAuto();
})();
</script>

