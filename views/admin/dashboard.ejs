<%- include('../partials/header') %>

<div class="admin-container">
  <% if (locals.flashMsg) { %>
    <div class="alert" style="background:#f0fdf4;border:1px solid #86efac;color:#166534;padding:12px 20px;border-radius:6px;margin-bottom:20px;font-size:0.85rem;"><%= flashMsg %></div>
  <% } %>
  <div class="admin-header">
    <h1>Admin Dashboard</h1>
    <a href="/admin/products/new" class="btn-primary">+ Add Product</a>
  </div>

  <div class="stats-grid">
    <div class="stat-card"><div class="stat-num"><%= stats.totalProducts %></div><div class="stat-label">Products</div></div>
    <div class="stat-card"><div class="stat-num"><%= stats.totalOrders %></div><div class="stat-label">Orders</div></div>
    <div class="stat-card"><div class="stat-num">₹<%= stats.totalRevenue.toFixed(2) %></div><div class="stat-label">Revenue</div></div>
    <div class="stat-card"><div class="stat-num"><%= stats.pendingOrders %></div><div class="stat-label">Pending</div></div>
  </div>

  <!-- Bulk Import/Export -->
  <div class="bulk-bar">
    <div class="bulk-bar-left">
      <h2 style="margin:0">Products</h2>
    </div>
    <div class="bulk-bar-right">
      <a href="/admin/products/export" class="btn-outline" style="font-size:0.78rem;">⬇ Download Excel</a>
      <form method="POST" action="/admin/products/import" enctype="multipart/form-data" class="bulk-import-form">
        <label class="btn-outline" style="font-size:0.78rem;cursor:pointer;">
          ⬆ Upload Excel
          <input type="file" name="bulkFile" accept=".xlsx,.xls,.csv" onchange="this.closest('form').submit()" style="display:none;">
        </label>
      </form>
    </div>
  </div>
  <p style="font-size:0.75rem;color:#898AC4;margin:-8px 0 16px;opacity:0.8;">Download the sheet, edit name / price / stock / category, then re-upload to apply changes in bulk.</p>

  <div class="admin-table-wrap">
    <table class="admin-table">
      <thead><tr><th>Image</th><th>Name</th><th>Price</th><th>Stock</th><th>Category</th><th>Actions</th></tr></thead>
      <tbody>
        <% products.forEach(p => { %>
          <tr>
            <td><img src="<%= p.image && p.image.startsWith('http') ? p.image : '/uploads/' + p.image %>" alt="<%= p.name %>" width="50" onerror="this.src='/images/placeholder.jpg'"></td>
            <td><%= p.name %></td>
            <td>₹<%= p.price.toFixed(2) %></td>
            <td><%= p.stock %></td>
            <td><%= p.category %></td>
            <td>
              <a href="/admin/products/edit/<%= p.id %>" class="btn-sm">Edit</a>
              <form method="POST" action="/admin/products/delete/<%= p.id %>" style="display:inline" onsubmit="return confirm('Delete this product?')">
                <button type="submit" class="btn-sm btn-danger">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <% if (totalPages > 1) { %>
  <nav class="pagination" style="padding: 24px 0 8px;">
    <% if (currentPage > 1) { %>
      <a href="/admin?page=<%= currentPage - 1 %>" class="page-btn page-prev">&#8592;</a>
    <% } %>
    <% for (let p = 1; p <= totalPages; p++) { %>
      <a href="/admin?page=<%= p %>" class="page-btn <%= p === currentPage ? 'active' : '' %>"><%= p %></a>
    <% } %>
    <% if (currentPage < totalPages) { %>
      <a href="/admin?page=<%= currentPage + 1 %>" class="page-btn page-next">&#8594;</a>
    <% } %>
  </nav>
  <% } %>

  <h2>Orders</h2>
  <div class="admin-table-wrap">
    <table class="admin-table">
      <thead><tr><th>#</th><th>Customer</th><th>Total</th><th>Status</th><th>Date</th><th>Update</th></tr></thead>
      <tbody>
        <% orders.forEach(o => { %>
          <tr>
            <td><%= o.id %></td>
            <td><%= o.user_name || o.name %></td>
            <td>₹<%= o.total.toFixed(2) %></td>
            <td><span class="badge badge-<%= o.status %>"><%= o.status %></span></td>
            <td><%= new Date(o.created_at).toLocaleDateString() %></td>
            <td>
              <form method="POST" action="/admin/orders/status/<%= o.id %>">
                <select name="status">
                  <option value="pending" <%= o.status==='pending'?'selected':'' %>>pending</option>
                  <option value="paid" <%= o.status==='paid'?'selected':'' %>>paid</option>
                  <option value="shipped" <%= o.status==='shipped'?'selected':'' %>>shipped</option>
                  <option value="delivered" <%= o.status==='delivered'?'selected':'' %>>delivered</option>
                  <option value="cancelled" <%= o.status==='cancelled'?'selected':'' %>>cancelled</option>
                </select>
                <button type="submit" class="btn-sm">Save</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>
