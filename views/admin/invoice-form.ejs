<%- include('../partials/header') %>

<div class="admin-container">
  <div class="admin-header">
    <h1 style="color:#898AC4;">New Offline Invoice</h1>
    <a href="/admin/invoices" style="font-size:0.82rem;color:#898AC4;">← All Invoices</a>
  </div>

  <form method="POST" action="/admin/invoices/new" id="invoiceForm">

    <!-- Customer Details -->
    <div style="background:#fff;border:1px solid #e8dde3;border-radius:10px;padding:28px 32px;margin-bottom:24px;">
      <h2 style="font-size:1rem;font-weight:700;color:#898AC4;margin-bottom:20px;letter-spacing:0.04em;">Customer Details</h2>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
        <div>
          <label style="font-size:0.75rem;font-weight:600;color:#898AC4;letter-spacing:0.08em;display:block;margin-bottom:6px;">CUSTOMER NAME *</label>
          <input type="text" name="customer_name" required placeholder="e.g. Priya Sharma"
            style="width:100%;padding:10px 14px;border:1px solid #e8dde3;border-radius:6px;font-size:0.9rem;color:#3a2e2e;outline:none;">
        </div>
        <div>
          <label style="font-size:0.75rem;font-weight:600;color:#898AC4;letter-spacing:0.08em;display:block;margin-bottom:6px;">PHONE</label>
          <input type="text" name="customer_phone" placeholder="e.g. 9876543210"
            style="width:100%;padding:10px 14px;border:1px solid #e8dde3;border-radius:6px;font-size:0.9rem;color:#3a2e2e;outline:none;">
        </div>
        <div style="grid-column:1/-1;">
          <label style="font-size:0.75rem;font-weight:600;color:#898AC4;letter-spacing:0.08em;display:block;margin-bottom:6px;">ADDRESS</label>
          <input type="text" name="customer_address" placeholder="Street, City"
            style="width:100%;padding:10px 14px;border:1px solid #e8dde3;border-radius:6px;font-size:0.9rem;color:#3a2e2e;outline:none;">
        </div>
      </div>
    </div>

    <!-- Line Items -->
    <div style="background:#fff;border:1px solid #e8dde3;border-radius:10px;padding:28px 32px;margin-bottom:24px;">
      <h2 style="font-size:1rem;font-weight:700;color:#898AC4;margin-bottom:20px;letter-spacing:0.04em;">Products</h2>

      <table style="width:100%;border-collapse:collapse;" id="itemsTable">
        <thead>
          <tr style="font-size:0.72rem;font-weight:700;color:#898AC4;letter-spacing:0.1em;text-transform:uppercase;border-bottom:2px solid #e8dde3;">
            <th style="padding:8px 10px;text-align:left;">Product</th>
            <th style="padding:8px 10px;text-align:left;width:90px;">Qty</th>
            <th style="padding:8px 10px;text-align:left;width:120px;">Unit Price (₹)</th>
            <th style="padding:8px 10px;text-align:right;width:110px;">Subtotal</th>
            <th style="width:40px;"></th>
          </tr>
        </thead>
        <tbody id="itemsBody">
          <tr class="item-row">
            <td style="padding:8px 6px;">
              <select name="product_id" onchange="fillPrice(this)" style="width:100%;padding:9px 10px;border:1px solid #e8dde3;border-radius:6px;font-size:0.85rem;color:#3a2e2e;">
                <option value="">— Select product —</option>
                <% products.forEach(p => { %>
                  <option value="<%= p.id %>" data-price="<%= Math.floor(p.price * 0.5) %>" data-stock="<%= p.stock %>">
                    <%= p.name %> (stock: <%= p.stock %>)
                  </option>
                <% }) %>
              </select>
            </td>
            <td style="padding:8px 6px;">
              <input type="number" name="quantity" value="1" min="1" onchange="updateRow(this)"
                style="width:100%;padding:9px 10px;border:1px solid #e8dde3;border-radius:6px;font-size:0.85rem;">
            </td>
            <td style="padding:8px 6px;">
              <input type="number" name="unit_price" value="" step="0.01" min="0" onchange="updateRow(this)"
                style="width:100%;padding:9px 10px;border:1px solid #e8dde3;border-radius:6px;font-size:0.85rem;">
            </td>
            <td style="padding:8px 10px;text-align:right;font-weight:600;color:#898AC4;" class="row-subtotal">₹0</td>
            <td style="padding:8px 6px;text-align:center;">
              <button type="button" onclick="removeRow(this)" style="background:none;border:none;color:#e57373;cursor:pointer;font-size:1rem;">✕</button>
            </td>
          </tr>
        </tbody>
      </table>

      <button type="button" onclick="addRow()" style="margin-top:14px;padding:8px 20px;background:#f5f0fb;color:#898AC4;border:1px dashed #898AC4;border-radius:6px;font-size:0.8rem;font-weight:600;cursor:pointer;">+ Add Another Product</button>

      <div style="margin-top:20px;text-align:right;border-top:2px solid #e8dde3;padding-top:16px;">
        <span style="font-size:1rem;font-weight:700;color:#898AC4;">Total: ₹<span id="grandTotal">0</span></span>
      </div>
    </div>

    <!-- Notes -->
    <div style="background:#fff;border:1px solid #e8dde3;border-radius:10px;padding:28px 32px;margin-bottom:28px;">
      <label style="font-size:0.75rem;font-weight:600;color:#898AC4;letter-spacing:0.08em;display:block;margin-bottom:8px;">NOTES (optional)</label>
      <textarea name="notes" rows="3" placeholder="Payment mode, special instructions..."
        style="width:100%;padding:10px 14px;border:1px solid #e8dde3;border-radius:6px;font-size:0.9rem;color:#3a2e2e;resize:vertical;outline:none;"></textarea>
    </div>

    <div style="display:flex;gap:14px;">
      <button type="submit" class="btn-primary">Generate Invoice & Print</button>
      <a href="/admin/invoices" class="btn-outline">Cancel</a>
    </div>
  </form>
</div>

<script>
  const productData = {};
  <% products.forEach(p => { %>
    productData[<%= p.id %>] = { price: <%= Math.floor(p.price * 0.5) %>, stock: <%= p.stock %> };
  <% }) %>

  function fillPrice(select) {
    const row = select.closest('.item-row');
    const pid = select.value;
    const priceInput = row.querySelector('[name="unit_price"]');
    if (pid && productData[pid]) {
      priceInput.value = productData[pid].price;
      row.querySelector('[name="quantity"]').max = productData[pid].stock;
    } else {
      priceInput.value = '';
    }
    updateRow(priceInput);
  }

  function updateRow(input) {
    const row = input.closest('.item-row');
    const qty   = parseFloat(row.querySelector('[name="quantity"]').value)  || 0;
    const price = parseFloat(row.querySelector('[name="unit_price"]').value) || 0;
    row.querySelector('.row-subtotal').textContent = '₹' + Math.floor(qty * price);
    updateTotal();
  }

  function updateTotal() {
    let total = 0;
    document.querySelectorAll('.item-row').forEach(row => {
      const qty   = parseFloat(row.querySelector('[name="quantity"]').value)  || 0;
      const price = parseFloat(row.querySelector('[name="unit_price"]').value) || 0;
      total += qty * price;
    });
    document.getElementById('grandTotal').textContent = Math.floor(total);
  }

  function addRow() {
    const tbody = document.getElementById('itemsBody');
    const first = tbody.querySelector('.item-row');
    const clone = first.cloneNode(true);
    clone.querySelector('select').value = '';
    clone.querySelector('[name="quantity"]').value = 1;
    clone.querySelector('[name="unit_price"]').value = '';
    clone.querySelector('.row-subtotal').textContent = '₹0';
    clone.querySelector('select').addEventListener('change', function(){ fillPrice(this); });
    clone.querySelector('[name="quantity"]').addEventListener('change', function(){ updateRow(this); });
    clone.querySelector('[name="unit_price"]').addEventListener('change', function(){ updateRow(this); });
    tbody.appendChild(clone);
  }

  function removeRow(btn) {
    const rows = document.querySelectorAll('.item-row');
    if (rows.length === 1) return;
    btn.closest('.item-row').remove();
    updateTotal();
  }
</script>

<%- include('../partials/footer') %>
