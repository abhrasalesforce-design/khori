<%- include('../partials/header') %>

<div class="page-container">
  <h1><%= product ? 'Edit Product' : 'New Product' %></h1>
  <% if (error && error.length) { %><div class="alert alert-error"><%= error %></div><% } %>

  <form method="POST" action="<%= product ? '/admin/products/edit/' + product.id : '/admin/products/new' %>" enctype="multipart/form-data" class="product-form">
    <div class="form-row">
      <label>Product Name *</label>
      <input type="text" name="name" value="<%= product ? product.name : '' %>" required>
    </div>
    <div class="form-row">
      <label>Description</label>
      <textarea name="description" id="description" rows="4"><%= product ? product.description : '' %></textarea>
      <button type="button" id="ai-generate-btn" onclick="generateDescription()" style="margin-top:8px;padding:8px 18px;background:#898AC4;color:#fff;border:none;cursor:pointer;font-size:0.82rem;letter-spacing:0.08em;">✦ Generate with AI</button>
      <span id="ai-status" style="margin-left:10px;font-size:0.8rem;color:#898AC4;"></span>
    </div>
    <div class="form-row two-col">
      <div>
        <label>Price (₹) *</label>
        <input type="number" name="price" value="<%= product ? product.price : '' %>" step="0.01" min="0" required>
      </div>
      <div>
        <label>Stock</label>
        <input type="number" name="stock" value="<%= product ? product.stock : '0' %>" min="0">
      </div>
    </div>
    <div class="form-row">
      <label>Category</label>
      <select name="category">
        <option value="jewellery" <%= product && product.category === 'jewellery' ? 'selected' : '' %>>Jewellery</option>
        <option value="decor" <%= product && product.category === 'decor' ? 'selected' : '' %>>Decor</option>
        <option value="others" <%= (product && product.category !== 'jewellery' && product.category !== 'decor') ? 'selected' : '' %>>Others</option>
      </select>
    </div>
    <div class="form-row">
      <label>Dimensions (L × B × H)</label>
      <div style="display:flex;align-items:center;gap:8px;">
        <input type="text" name="dim_l" placeholder="L" style="width:80px;" value="<%= product && product.dimension ? product.dimension.split('×')[0].trim() : '' %>">
        <span style="font-weight:600;font-size:1.1rem;">×</span>
        <input type="text" name="dim_b" placeholder="B" style="width:80px;" value="<%= product && product.dimension ? (product.dimension.split('×')[1] || '').trim() : '' %>">
        <span style="font-weight:600;font-size:1.1rem;">×</span>
        <input type="text" name="dim_h" placeholder="H" style="width:80px;" value="<%= product && product.dimension ? (product.dimension.split('×')[2] || '').trim() : '' %>">
      </div>
    </div>
    <div class="form-row">
      <label>Product Image</label>
      <% if (product && product.image !== 'placeholder.jpg') { %>
        <img src="/uploads/<%= product.image %>" width="100" style="display:block;margin-bottom:8px;">
      <% } %>
      <input type="file" name="image" accept="image/*">
    </div>
    <div class="form-actions">
      <button type="submit" class="btn-primary"><%= product ? 'Save Changes' : 'Add Product' %></button>
      <a href="/admin" class="btn-outline">Cancel</a>
    </div>
  </form>
</div>

<script>
async function generateDescription() {
  const imageInput = document.querySelector('input[name="image"]');
  const nameInput = document.querySelector('input[name="name"]');
  const categoryInput = document.querySelector('select[name="category"]');
  const btn = document.getElementById('ai-generate-btn');
  const status = document.getElementById('ai-status');

  if (!imageInput.files || !imageInput.files[0]) {
    status.textContent = 'Please select a product image first.';
    status.style.color = '#c0676a';
    return;
  }

  btn.disabled = true;
  btn.textContent = 'Generating...';
  status.textContent = '';
  status.style.color = '#898AC4';

  const formData = new FormData();
  formData.append('image', imageInput.files[0]);
  formData.append('name', nameInput.value || '');
  formData.append('category', categoryInput.value || '');

  try {
    const res = await fetch('/admin/generate-description', { method: 'POST', body: formData });
    const data = await res.json();
    if (data.description) {
      document.getElementById('description').value = data.description;
      status.textContent = 'Description generated!';
      status.style.color = '#2e7d32';
    } else {
      status.textContent = data.error || 'Failed to generate.';
      status.style.color = '#c0676a';
    }
  } catch (e) {
    status.textContent = 'Error connecting to AI.';
    status.style.color = '#c0676a';
  }

  btn.disabled = false;
  btn.textContent = '✦ Generate with AI';
}
</script>

<%- include('../partials/footer') %>
