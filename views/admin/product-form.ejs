<%- include('../partials/header') %>

<div class="page-container">
  <h1><%= product ? 'Edit Product' : 'New Product' %></h1>
  <% if (error && error.length) { %><div class="alert alert-error"><%= error %></div><% } %>

  <form method="POST" action="<%= product ? '/admin/products/edit/' + product.id : '/admin/products/new' %>" enctype="multipart/form-data" class="product-form">
    <div class="form-row">
      <label>Product Name *</label>
      <input type="text" name="name" value="<%= product ? product.name : '' %>" required>
    </div>
    <div class="form-row">
      <label>Description</label>
      <textarea name="description" rows="4"><%= product ? product.description : '' %></textarea>
    </div>
    <div class="form-row two-col">
      <div>
        <label>Price (₹) *</label>
        <input type="number" name="price" value="<%= product ? product.price : '' %>" step="0.01" min="0" required>
      </div>
      <div>
        <label>Stock</label>
        <input type="number" name="stock" value="<%= product ? product.stock : '0' %>" min="0">
      </div>
    </div>
    <div class="form-row">
      <label>Category</label>
      <select name="category">
        <option value="jewellery" <%= product && product.category === 'jewellery' ? 'selected' : '' %>>Jewellery</option>
        <option value="decor" <%= product && product.category === 'decor' ? 'selected' : '' %>>Decor</option>
        <option value="others" <%= (product && product.category !== 'jewellery' && product.category !== 'decor') ? 'selected' : '' %>>Others</option>
      </select>
    </div>
    <div class="form-row">
      <label>Dimensions (L × B × H)</label>
      <div style="display:flex;align-items:center;gap:8px;">
        <input type="text" name="dim_l" placeholder="L" style="width:80px;" value="<%= product && product.dimension ? product.dimension.split('×')[0].trim() : '' %>">
        <span style="font-weight:600;font-size:1.1rem;">×</span>
        <input type="text" name="dim_b" placeholder="B" style="width:80px;" value="<%= product && product.dimension ? (product.dimension.split('×')[1] || '').trim() : '' %>">
        <span style="font-weight:600;font-size:1.1rem;">×</span>
        <input type="text" name="dim_h" placeholder="H" style="width:80px;" value="<%= product && product.dimension ? (product.dimension.split('×')[2] || '').trim() : '' %>">
      </div>
    </div>
    <div class="form-row">
      <label>Material</label>
      <input type="text" name="material" value="<%= product ? (product.material || '') : '' %>" placeholder="e.g. Terracotta, Brass, Cotton">
    </div>
    <div class="form-row">
      <label>Craft Type</label>
      <input type="text" name="craft_type" value="<%= product ? (product.craft_type || '') : '' %>" placeholder="e.g. Hand-painted, Block print, Woven">
    </div>
    <div class="form-row">
      <label>Origin</label>
      <input type="text" name="origin" value="<%= product ? (product.origin || '') : '' %>" placeholder="e.g. West Bengal, Rajasthan">
    </div>
    <div class="form-row">
      <label>Care Instructions</label>
      <input type="text" name="care_instructions" value="<%= product ? (product.care_instructions || '') : '' %>" placeholder="e.g. Wipe clean with dry cloth">
    </div>
    <div class="form-row">
      <label>Product Image</label>
      <% if (product && product.image !== 'placeholder.jpg') { %>
        <img src="/uploads/<%= product.image %>" width="100" style="display:block;margin-bottom:8px;">
      <% } %>
      <input type="file" name="image" accept="image/*">
    </div>
    <div class="form-actions">
      <button type="submit" class="btn-primary"><%= product ? 'Save Changes' : 'Add Product' %></button>
      <a href="/admin" class="btn-outline">Cancel</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
