<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Hathekhori — handmade crafts rooted in Bengali tradition. Shop pottery, textiles, decor, jewellery and more, crafted by artisans across India.">
  <meta name="theme-color" content="#F6F4E8">
  <title>Hathekhori – Handmade Crafts</title>

  <!-- Preconnect for fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <!-- Non-render-blocking font load -->
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&family=Hind+Siliguri:wght@400;600&family=Great+Vibes&display=swap">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&family=Hind+Siliguri:wght@400;600&family=Great+Vibes&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
  <noscript><link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&family=Hind+Siliguri:wght@400;600&family=Great+Vibes&display=swap" rel="stylesheet"></noscript>

  <link rel="stylesheet" href="/css/style.css?v=<%= locals.buildVersion %>">

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-MLV8DMQJ3Q"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-MLV8DMQJ3Q');
  </script>
</head>
<body>
<header>
  <div class="header-inner">
    <a href="/" class="logo">
      <picture>
        <source srcset="<%= cdn && cdn['logo.webp'] ? cdn['logo.webp'] : '/images/logo.webp' %>" type="image/webp">
        <img src="<%= cdn && cdn['logo.png'] ? cdn['logo.png'] : '/images/logo.png' %>" alt="Hathekhori – Handmade Crafts" width="900" height="297" loading="eager" fetchpriority="high">
      </picture>
    </a>

    <!-- Desktop nav -->
    <nav class="desktop-nav" aria-label="Main navigation">

      <!-- Craft Collection mega-dropdown -->
      <div class="nav-dropdown">
        <button class="nav-dropdown-toggle">Craft Collection ▾</button>
        <div class="nav-mega-menu">
          <div class="nav-mega-col">
            <a href="/collection/wearable-art" class="nav-mega-heading">Wearable Art</a>
            <a href="/collection/wearable-art?sub=earrings">Earrings</a>
            <a href="/collection/wearable-art?sub=pendants">Fabric Painted Pendants</a>
            <a href="/collection/wearable-art?sub=terracotta">Terracotta Jewellery</a>
          </div>
          <div class="nav-mega-col">
            <a href="/collection/artisan-totes" class="nav-mega-heading">Artisan Totes</a>
            <a href="/collection/artisan-totes?sub=embroidered">Embroidered Tote Bags</a>
            <a href="/collection/artisan-totes?sub=hand-painted">Hand Painted Tote Bags</a>
          </div>
          <div class="nav-mega-col">
            <a href="/collection/canvas-tales" class="nav-mega-heading">Canvas Tales</a>
            <a href="/collection/canvas-tales?sub=mini-canvas">Mini Canvas Art</a>
            <a href="/collection/canvas-tales?sub=scenic">Scenic Mini Canvases</a>
            <a href="/collection/canvas-tales?sub=mdf">Round MDF Paintings</a>
          </div>
          <div class="nav-mega-col">
            <a href="/collection/handmade-treasures" class="nav-mega-heading">Handmade Treasures</a>
            <a href="/collection/handmade-treasures?sub=diaries">Hand Block Diaries</a>
            <a href="/collection/handmade-treasures?sub=keychains">Diary Keychains</a>
            <a href="/collection/handmade-treasures?sub=frames">Handcrafted Photo Frames</a>
            <a href="/collection/handmade-treasures?sub=bookmarks">Artistic Bookmarks</a>
          </div>
        </div>
      </div>

      <a href="/about">Who We Are</a>
      <a href="/#artforms">Art Forms</a>
      <% if (user) { %>
        <a href="/orders">My Orders</a>
        <a href="/wishlist">Wishlist</a>
        <% if (user.is_admin) { %><a href="/admin">Admin</a><% } %>
        <a href="/logout">Logout</a>
      <% } else { %>
        <a href="/login">Login</a>
        <a href="/register">Register</a>
      <% } %>
      <a href="/cart" class="cart-link">Cart</a>
    </nav>

    <!-- Hamburger button -->
    <button class="hamburger" id="hamburger" aria-label="Open navigation menu" aria-expanded="false" aria-controls="mobileMenu">
      <span class="ham-line"></span>
      <span class="ham-line"></span>
      <span class="ham-label">MENU</span>
    </button>
  </div>

  <!-- Dark backdrop -->
  <div class="mobile-menu-backdrop" id="menuBackdrop"></div>

  <!-- Slide-in sidebar menu -->
  <div class="mobile-menu" id="mobileMenu" role="dialog" aria-label="Navigation menu">
    <div class="mobile-menu-inner">
      <div class="mobile-menu-close">
        <button onclick="closeMenu()" aria-label="Close menu">✕</button>
      </div>
      <nav class="mobile-nav" aria-label="Mobile navigation">

        <!-- Craft Collection parent accordion -->
        <div class="mobile-nav-group">
          <button class="mobile-nav-group-toggle">
            Craft Collection <em class="toggle-arrow">▾</em>
          </button>
          <div class="mobile-nav-sub">

            <!-- Wearable Art -->
            <div class="mobile-nav-group mobile-nav-group-inner">
              <button class="mobile-nav-group-toggle mobile-nav-group-toggle-inner">
                Wearable Art <em class="toggle-arrow">▾</em>
              </button>
              <div class="mobile-nav-sub mobile-nav-sub-inner">
                <a href="/collection/wearable-art?sub=earrings" onclick="closeMenu()">Earrings</a>
                <a href="/collection/wearable-art?sub=pendants" onclick="closeMenu()">Fabric Painted Pendants</a>
                <a href="/collection/wearable-art?sub=terracotta" onclick="closeMenu()">Terracotta Jewellery</a>
              </div>
            </div>

            <!-- Artisan Totes -->
            <div class="mobile-nav-group mobile-nav-group-inner">
              <button class="mobile-nav-group-toggle mobile-nav-group-toggle-inner">
                Artisan Totes <em class="toggle-arrow">▾</em>
              </button>
              <div class="mobile-nav-sub mobile-nav-sub-inner">
                <a href="/collection/artisan-totes?sub=embroidered" onclick="closeMenu()">Embroidered Tote Bags</a>
                <a href="/collection/artisan-totes?sub=hand-painted" onclick="closeMenu()">Hand Painted Tote Bags</a>
              </div>
            </div>

            <!-- Canvas Tales -->
            <div class="mobile-nav-group mobile-nav-group-inner">
              <button class="mobile-nav-group-toggle mobile-nav-group-toggle-inner">
                Canvas Tales <em class="toggle-arrow">▾</em>
              </button>
              <div class="mobile-nav-sub mobile-nav-sub-inner">
                <a href="/collection/canvas-tales?sub=mini-canvas" onclick="closeMenu()">Mini Canvas Art</a>
                <a href="/collection/canvas-tales?sub=scenic" onclick="closeMenu()">Scenic Mini Canvases</a>
                <a href="/collection/canvas-tales?sub=mdf" onclick="closeMenu()">Round MDF Paintings</a>
              </div>
            </div>

            <!-- Handmade Treasures -->
            <div class="mobile-nav-group mobile-nav-group-inner">
              <button class="mobile-nav-group-toggle mobile-nav-group-toggle-inner">
                Handmade Treasures <em class="toggle-arrow">▾</em>
              </button>
              <div class="mobile-nav-sub mobile-nav-sub-inner">
                <a href="/collection/handmade-treasures?sub=diaries" onclick="closeMenu()">Hand Block Diaries</a>
                <a href="/collection/handmade-treasures?sub=keychains" onclick="closeMenu()">Diary Keychains</a>
                <a href="/collection/handmade-treasures?sub=frames" onclick="closeMenu()">Handcrafted Photo Frames</a>
                <a href="/collection/handmade-treasures?sub=bookmarks" onclick="closeMenu()">Artistic Bookmarks</a>
              </div>
            </div>

          </div>
        </div>

        <a href="/about" class="mobile-nav-link" onclick="closeMenu()">Who We Are</a>
        <a href="/#artforms" class="mobile-nav-link" onclick="closeMenu()">Art Forms</a>
        <% if (user) { %>
          <a href="/orders" class="mobile-nav-link" onclick="closeMenu()">My Orders</a>
          <a href="/wishlist" class="mobile-nav-link" onclick="closeMenu()">Wishlist</a>
          <% if (user.is_admin) { %>
            <a href="/admin" class="mobile-nav-link" onclick="closeMenu()">Admin</a>
          <% } %>
          <a href="/logout" class="mobile-nav-link">Logout</a>
        <% } else { %>
          <a href="/login" class="mobile-nav-link" onclick="closeMenu()">Login</a>
          <a href="/register" class="mobile-nav-link" onclick="closeMenu()">Register</a>
        <% } %>
      </nav>
      <div class="mobile-menu-footer">
        <a href="/cart" class="mobile-cart-btn" onclick="closeMenu()">View Cart</a>
        <% if (user) { %>
          <p class="mobile-user-name"><%= user.name %></p>
        <% } %>
      </div>
    </div>
  </div>
</header>

<script>
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');
  const backdrop = document.getElementById('menuBackdrop');
  hamburger.addEventListener('click', () => {
    const open = hamburger.classList.toggle('open');
    mobileMenu.classList.toggle('open');
    backdrop.classList.toggle('open');
    document.body.classList.toggle('menu-open');
    hamburger.setAttribute('aria-expanded', open);
    hamburger.setAttribute('aria-label', open ? 'Close navigation menu' : 'Open navigation menu');
  });
  function closeMenu() {
    hamburger.classList.remove('open');
    mobileMenu.classList.remove('open');
    backdrop.classList.remove('open');
    document.body.classList.remove('menu-open');
    hamburger.setAttribute('aria-expanded', 'false');
    hamburger.setAttribute('aria-label', 'Open navigation menu');
  }
  backdrop.addEventListener('click', closeMenu);

  // Desktop dropdown toggles
  document.querySelectorAll('.nav-dropdown-toggle').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      const dropdown = btn.closest('.nav-dropdown');
      const isOpen = dropdown.classList.contains('open');
      // Close all dropdowns first
      document.querySelectorAll('.nav-dropdown').forEach(function(d) { d.classList.remove('open'); });
      if (!isOpen) dropdown.classList.add('open');
    });
  });
  // Close desktop dropdowns when clicking outside
  document.addEventListener('click', function(e) {
    if (!e.target.closest('.nav-dropdown')) {
      document.querySelectorAll('.nav-dropdown').forEach(function(d) { d.classList.remove('open'); });
    }
  });

  // Mobile accordion toggles
  document.querySelectorAll('.mobile-nav-group-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      btn.closest('.mobile-nav-group').classList.toggle('open');
    });
  });
</script>

<main>
