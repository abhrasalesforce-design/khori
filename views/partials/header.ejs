<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Khori – Handmade Crafts</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&family=Hind+Siliguri:wght@400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<header>
  <div class="header-inner">
    <a href="/" class="logo"><img src="/images/logo.png" alt="Hate Khori"></a>

    <!-- Desktop nav -->
    <nav class="desktop-nav">
      <a href="/#shop">Art Works</a>
      <a href="/#overview">Overview</a>
      <a href="/#artforms">Art Forms</a>
      <% if (user) { %>
        <a href="/orders">My Orders</a>
        <% if (user.is_admin) { %><a href="/admin">Admin</a><% } %>
        <a href="/logout">Logout</a>
      <% } else { %>
        <a href="/login">Login</a>
        <a href="/register">Register</a>
      <% } %>
      <a href="/cart" class="cart-link">Cart</a>
    </nav>

    <!-- Hamburger button -->
    <button class="hamburger" id="hamburger" aria-label="Menu">
      <span class="ham-line"></span>
      <span class="ham-line"></span>
      <span class="ham-label">MENU</span>
    </button>
  </div>

  <!-- Full-screen mobile menu -->
  <div class="mobile-menu" id="mobileMenu">
    <div class="mobile-menu-inner">
      <nav class="mobile-nav">
        <a href="/#shop" class="mobile-nav-link" onclick="closeMenu()">Art Works</a>
        <a href="/#overview" class="mobile-nav-link" onclick="closeMenu()">Overview</a>
        <a href="/#artforms" class="mobile-nav-link" onclick="closeMenu()">Art Forms</a>
        <% if (user) { %>
          <a href="/orders" class="mobile-nav-link" onclick="closeMenu()">My Orders</a>
          <% if (user.is_admin) { %>
            <a href="/admin" class="mobile-nav-link" onclick="closeMenu()">Admin</a>
          <% } %>
          <a href="/logout" class="mobile-nav-link">Logout</a>
        <% } else { %>
          <a href="/login" class="mobile-nav-link" onclick="closeMenu()">Login</a>
          <a href="/register" class="mobile-nav-link" onclick="closeMenu()">Register</a>
        <% } %>
      </nav>
      <div class="mobile-menu-footer">
        <a href="/cart" class="mobile-cart-btn" onclick="closeMenu()">View Cart</a>
        <% if (user) { %>
          <p class="mobile-user-name"><%= user.name %></p>
        <% } %>
      </div>
    </div>
  </div>
</header>

<script>
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');
  hamburger.addEventListener('click', () => {
    hamburger.classList.toggle('open');
    mobileMenu.classList.toggle('open');
    document.body.classList.toggle('menu-open');
  });
  function closeMenu() {
    hamburger.classList.remove('open');
    mobileMenu.classList.remove('open');
    document.body.classList.remove('menu-open');
  }
  document.addEventListener('click', (e) => {
    if (!hamburger.contains(e.target) && !mobileMenu.contains(e.target)) closeMenu();
  });
</script>

<main>
