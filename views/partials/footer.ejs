<!-- Contact Us slide-up banner -->
<div id="contactBanner" style="
  position:fixed; bottom:0; left:0; right:0; z-index:8000;
  background:#fff; border-top:2px solid #e8dde3;
  box-shadow:0 -4px 24px rgba(58,46,46,0.12);
  transform:translateY(100%); transition:transform 0.35s cubic-bezier(0.4,0,0.2,1);
  padding:28px 24px 24px; max-height:90vh; overflow-y:auto;
">
  <div style="max-width:480px;margin:0 auto;position:relative;">
    <button onclick="closeContactBanner()" style="position:absolute;top:-8px;right:0;background:none;border:none;font-size:1.3rem;color:#aaa;cursor:pointer;line-height:1;">✕</button>
    <h3 style="font-family:'Playfair Display',Georgia,serif;font-size:1.2rem;color:#898AC4;margin-bottom:4px;">Contact Us</h3>
    <p style="font-size:0.8rem;color:#898AC4;margin-bottom:16px;">Or email us directly at <a href="mailto:contact.hathekhori@gmail.com" style="color:#898AC4;font-weight:600;">contact.hathekhori@gmail.com</a></p>
    <form id="contactBannerForm" onsubmit="sendContactBanner(event)">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px;">
        <input type="text" id="cbName" placeholder="Your name" required style="padding:9px 12px;border:1px solid rgba(137,138,196,0.35);border-radius:6px;font-size:0.85rem;font-family:'Inter',sans-serif;outline:none;color:#3a2e2e;">
        <input type="email" id="cbEmail" placeholder="Your email" required style="padding:9px 12px;border:1px solid rgba(137,138,196,0.35);border-radius:6px;font-size:0.85rem;font-family:'Inter',sans-serif;outline:none;color:#3a2e2e;">
      </div>
      <textarea id="cbMsg" rows="3" placeholder="Your message…" required style="width:100%;padding:9px 12px;border:1px solid rgba(137,138,196,0.35);border-radius:6px;font-size:0.85rem;font-family:'Inter',sans-serif;outline:none;color:#3a2e2e;resize:none;margin-bottom:10px;box-sizing:border-box;"></textarea>
      <button type="submit" id="cbBtn" style="width:100%;padding:11px;background:#898AC4;color:#fff;border:none;border-radius:6px;font-size:0.85rem;font-weight:600;cursor:pointer;font-family:'Inter',sans-serif;transition:background 0.2s;">Send Message</button>
      <p id="cbStatus" style="display:none;margin-top:8px;font-size:0.8rem;text-align:center;"></p>
    </form>
  </div>
</div>
<div id="contactBannerBackdrop" onclick="closeContactBanner()" style="display:none;position:fixed;inset:0;z-index:7999;background:rgba(58,46,46,0.3);"></div>

<script>
function openContactBanner(e) {
  if (e) e.preventDefault();
  document.getElementById('contactBanner').style.transform = 'translateY(0)';
  document.getElementById('contactBannerBackdrop').style.display = 'block';
}
function closeContactBanner() {
  document.getElementById('contactBanner').style.transform = 'translateY(100%)';
  document.getElementById('contactBannerBackdrop').style.display = 'none';
}

async function sendContactBanner(e) {
  e.preventDefault();
  const btn = document.getElementById('cbBtn');
  const status = document.getElementById('cbStatus');
  const name = document.getElementById('cbName').value.trim();
  const email = document.getElementById('cbEmail').value.trim();
  const message = document.getElementById('cbMsg').value.trim();
  btn.disabled = true; btn.textContent = 'Sending…';
  status.style.display = 'none';
  let sent = false;
  try {
    const csrfToken = document.querySelector('meta[name="csrf-token"]').content;
    const res = await fetch('/contact', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
      body: JSON.stringify({ name, email, message })
    });
    if (res.ok) sent = true;
  } catch (_) {}

  if (sent) {
    status.textContent = '✓ Message sent! We\'ll get back to you soon.';
    status.style.color = '#4caf50'; status.style.display = 'block';
    e.target.reset();
  } else {
    // Fallback: open mailto so nothing is lost
    const subject = encodeURIComponent('Message from ' + name + ' via hathekhori.com');
    const body = encodeURIComponent('Name: ' + name + '\nEmail: ' + email + '\n\n' + message);
    window.location.href = 'mailto:contact.hathekhori@gmail.com?subject=' + subject + '&body=' + body;
    status.textContent = 'Opening your email app… or write directly to contact.hathekhori@gmail.com';
    status.style.color = '#898AC4'; status.style.display = 'block';
  }
  btn.disabled = false; btn.textContent = 'Send Message';
}

  // WebP support detection for CSS background fallbacks
  (function(){
    var i = new Image();
    i.onload = i.onerror = function(){ document.documentElement.classList.add(i.height===1?'webp':'no-webp'); };
    i.src = 'data:image/webp;base64,UklGRiQAAABXRUJQVlA4IBgAAAAwAQCdASoBAAEAAQAcJZACdAEO/gHOAAA=';
  })();
</script>
</body>
</html>
