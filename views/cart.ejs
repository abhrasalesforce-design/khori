<%- include('partials/header') %>

<div class="page-container">
  <h1>Your Cart</h1>

  <% if (items.length === 0) { %>
    <div class="empty-cart">
      <p>Your cart is empty.</p>
      <a href="/" class="btn-primary">Continue Shopping</a>
    </div>
  <% } else { %>
    <div class="cart-layout">
      <div class="cart-items">
        <% items.forEach(item => { %>
          <div class="cart-item">
            <img src="<%= item.image && item.image.startsWith('http') ? item.image : '/uploads/' + item.image %>" alt="<%= item.name %>" loading="lazy" decoding="async" onerror="this.src='/images/placeholder.jpg'">
            <div class="cart-item-info">
              <h3><a href="/product/<%= item.id %>"><%= item.name %></a></h3>
              <p>₹<%= item.price.toFixed(2) %> each</p>
            </div>
            <div class="cart-subtotal">₹<%= item.subtotal.toFixed(2) %></div>
            <div class="cart-item-actions">
              <form method="POST" action="/cart/update" class="qty-form">
                <input type="hidden" name="product_id" value="<%= item.id %>">
                <input type="number" name="quantity" value="<%= item.quantity %>" min="1" max="<%= item.stock %>">
                <button type="submit">Update</button>
              </form>
            </div>
            <div class="cart-item-remove">
              <form method="POST" action="/cart/remove">
                <input type="hidden" name="product_id" value="<%= item.id %>">
                <button type="submit" class="btn-remove">✕ Remove</button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>

      <div class="cart-summary">
        <h2>Order Summary</h2>
        <div class="summary-row"><span>Subtotal</span><span>₹<%= total.toFixed(2) %></span></div>
        <div class="summary-row"><span>Shipping</span><span>Free</span></div>
        <div class="summary-row total-row"><span>Total</span><span>₹<%= total.toFixed(2) %></span></div>
        <% if (user) { %>
          <a href="/checkout" class="btn-primary full-width">Proceed to Checkout</a>
        <% } else { %>
          <a href="/login" class="btn-primary full-width">Login to Checkout</a>
        <% } %>
        <a href="/" class="btn-outline full-width">Continue Shopping</a>
      </div>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
